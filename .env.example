# Para desarrollo local con `vercel dev`, copia este archivo como .env.local
# y pon tu clave real. .env.local está en .gitignore: NO se sube a GitHub.
# En Vercel, estas variables se cargan en Project Settings → Environment Variables.

APISPORTS_KEY=tu_clave_de_api_football_aqui
WC_LEAGUE=1
WC_SEASON=2026
CACHE_TTL=600

# Si usas la variante por RapidAPI en vez de api-sports.io directo, descomenta:
# APISPORTS_HOST=api-football-v1.p.rapidapi.com
# APISPORTS_RAPIDAPI=1
